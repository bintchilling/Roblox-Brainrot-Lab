{
  "name": "Brainrot Lab",
  "tree": {
    "$className": "DataModel",

    "Workspace": {
      "$path": "scripts/Scene"
    },

    "ReplicatedStorage": {
      "Shared": {
        "$path": "scripts/Shared"
      },
      "Remotes": {
        "$className": "Folder",
        "BuyUnit": { "$className": "RemoteEvent" },
        "FuseUnits": { "$className": "RemoteEvent" },
        "ClaimDaily": { "$className": "RemoteEvent" },
        "Rebirth": { "$className": "RemoteEvent" },
        "ConfirmRebirth": { "$className": "RemoteEvent" },
        "GlitchTriggered": { "$className": "RemoteEvent" },
        "GlitchClicked": { "$className": "RemoteEvent" },
        "RequestTrade": { "$className": "RemoteEvent" },
        "RespondTrade": { "$className": "RemoteEvent" },
        "UpdateTradeOffer": { "$className": "RemoteEvent" },
        "ConfirmTrade": { "$className": "RemoteEvent" },
        "CancelTrade": { "$className": "RemoteEvent" },
        "TradeStateChanged": { "$className": "RemoteEvent" },
        "InventoryUpdated": { "$className": "RemoteEvent" },
        "PlaceUnit": { "$className": "RemoteEvent" },
        "UnplaceUnit": { "$className": "RemoteEvent" },
        "GetInventory": { "$className": "RemoteFunction" }
      }
    },

    "ServerScriptService": {
      "Server": {
        "$path": "scripts/Server"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "ClientBootstrap": {
          "$path": "scripts/Client/ClientBootstrap",
          "$properties": {
            "RunContext": "Client"
          }
        },
        "Theme": {
          "$path": "scripts/Client/Theme.lua"
        },
        "StateManager": {
          "$path": "scripts/Client/StateManager.lua"
        },
        "Components": {
          "$path": "scripts/Client/Components"
        },
        "Controllers": {
          "$path": "scripts/Client/Controllers"
        }
      }
    },

    "StarterGui": {
      "$path": "scripts/UI"
    }
  }
}
